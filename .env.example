# ─── AUTH ─────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-super-secret-key-here-min-32-chars

# ─── GOOGLE APPS SCRIPT ───────────────────
# URL Web App setelah deploy Google Apps Script
NEXT_PUBLIC_GAS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Token keamanan (sama dengan yang ada di Apps Script)
NEXT_PUBLIC_GAS_TOKEN=YOUR_SECRET_TOKEN_HERE

# ─── CLOUDFLARE D1 (untuk migration via drizzle-kit) ──
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_DATABASE_ID=your-d1-database-id
CLOUDFLARE_D1_TOKEN=your-cloudflare-api-token

# ─── APP URL ──────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Production:
# NEXTAUTH_URL=https://jurnal.yourdomain.com
